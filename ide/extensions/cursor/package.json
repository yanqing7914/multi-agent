{
  "name": "multi-agent-panel-cursor",
  "displayName": "Multi-Agent Panel for Cursor (Phase 1)",
  "description": "Cursor-flavored scaffold: webview to ide/multi-agent-panel (local dev only).",
  "version": "0.1.0",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:multiAgentCursor.openPanel"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "check": "tsc --noEmit -p .",
    "package": "vsce package --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "multiAgentCursor.openPanel",
        "title": "Cursor: Open Multi-Agent Panel"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.4.0"
  }
}
